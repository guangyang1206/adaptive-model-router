# Copy to .env and fill in. Required vars fail-fast at boot naming the missing
# one (A14). See packages/control-plane/src/env.ts.

# --- REQUIRED ---------------------------------------------------------------
# Postgres connection string. For docker-compose this is set automatically.
DATABASE_URL=postgres://adaptive:adaptive@localhost:5432/adaptive_control_plane

# Secret used by Better-Auth to sign sessions/cookies. Generate a strong random
# value, e.g.  openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# Public base URL of this deployment (used for OAuth callbacks + cookie domain).
BETTER_AUTH_URL=http://localhost:3000

# --- OPTIONAL ---------------------------------------------------------------
# Server bind (defaults: PORT=3000, HOST=0.0.0.0).
PORT=3000
HOST=0.0.0.0

# Postgres password for the docker-compose db service (defaults to "adaptive").
POSTGRES_PASSWORD=adaptive

# GitHub OAuth (both must be set to enable the GitHub sign-in button).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Set to "false" to lock a fresh instance BEFORE the first user registers (A1).
REGISTRATION_OPEN=true
