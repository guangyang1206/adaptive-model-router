{
  "name": "@adaptive-router/control-plane",
  "version": "0.0.0",
  "description": "Self-hostable multi-user team control plane for Adaptive Model Router.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
