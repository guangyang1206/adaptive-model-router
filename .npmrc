; Optional peer dependencies (e.g. @huggingface/transformers for local ONNX
; embeddings) must NOT be auto-installed. The core SDK is zero-dependency and
; loads such peers only at runtime via a dynamic import shim. Auto-installing
; them would pull heavy native packages (onnxruntime, sharp) into node_modules
; and list them as resolved SDK dependencies in the lockfile, breaking the
; zero-dependency guarantee.
auto-install-peers=false
